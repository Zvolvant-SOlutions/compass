# Streamlit Cloud secrets for Compass.
# In the Streamlit Cloud dashboard → app settings → Secrets, paste a TOML block
# matching this template. Locally, use a .env file instead — see .env.example.

# --- Azure AD / Entra (v2 SSO; leave blank for v1 bcrypt auth) -------------
AZURE_AD_TENANT_ID = ""
AZURE_AD_CLIENT_ID = ""
AZURE_AD_CLIENT_SECRET = ""

# --- Azure DevOps integration (v2; leave blank for v1 seed data) ----------
ADO_ORG = ""
ADO_PROJECT = ""
ADO_PAT = ""

# --- App-level salt ---------------------------------------------------------
COMPASS_HASH_SALT = "change-me-in-production"

# --- Database path ----------------------------------------------------------
# Streamlit Cloud containers reset their disk on restart, so for production
# you'd point this at an Azure SQL connection string or similar. Leave blank
# to use the default ./compass.db (regenerated from seed_db.py on first run).
COMPASS_DB_PATH = ""
