# Local SQLite database path. Defaults to ./compass.db.
COMPASS_DB_PATH=compass.db

# Azure AD / Entra OAuth (when SSO is enabled in v2).
# Leave blank for v1 — Compass falls back to bcrypt local auth.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Azure DevOps REST integration (when live ADO sync is enabled in v2).
# Leave blank for v1 — Compass uses seeded mock sprint data.
ADO_ORG=
ADO_PROJECT=
ADO_PAT=

# Anthropic Claude (lights up the Story Builder page).
# Leave blank to disable LLM-backed features.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Daily $-cap for Claude usage (USD per UTC day). Default $10/day.
# Prevents a runaway page from draining the key.
COMPASS_ANTHROPIC_DAILY_USD_CAP=10

# Salt prefix for any non-bcrypt hashes (audit log identifiers, etc.)
COMPASS_HASH_SALT=change-me-in-production
